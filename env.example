OPENAI_API_KEY="api-key"
LLM_MODEL_NAME="model-name"

# CSV paths (optional)
# Defaults:
# - BBC_CSV_PATH=csv/bbc-news-data.csv
# - TAYLOR_SWIFT_CSV_PATH=csv/TaylorSwift13.csv
BBC_CSV_PATH="csv/bbc-news-data.csv"
TAYLOR_SWIFT_CSV_PATH="csv/TaylorSwift13.csv"

# Characterization corpus token budget (applies to the CORPUS block only)
# The corpus will be truncated to fit this budget using OpenAI's token counter.
CHAR_CORPUS_MAX_INPUT_TOKENS="8000"

# Optional: model to use for token counting. Defaults to LLM_MODEL_NAME if unset.
CHAR_CORPUS_TOKEN_COUNT_MODEL="gpt-5"